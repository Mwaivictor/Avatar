# Avatar Transformation System - Environment Configuration
# Copy this file to .env and customize as needed.

# ─── Camera Settings ───────────────────────────────────────────────
AVATAR_CAMERA_INDEX=0
AVATAR_FRAME_WIDTH=640
AVATAR_FRAME_HEIGHT=480
AVATAR_TARGET_FPS=30

# ─── Audio Settings ────────────────────────────────────────────────
AVATAR_SAMPLE_RATE=16000
AVATAR_AUDIO_CHANNELS=1
AVATAR_AUDIO_CHUNK=1024

# ─── AI Service Endpoints ─────────────────────────────────────────
AVATAR_FACE_ANIMATION_URL=http://localhost:8001
AVATAR_VOICE_CONVERSION_URL=http://localhost:8002
AVATAR_LIP_SYNC_URL=http://localhost:8003
AVATAR_SERVICE_TIMEOUT=0.5

# ─── Output Settings ──────────────────────────────────────────────
AVATAR_OUTPUT_WIDTH=640
AVATAR_OUTPUT_HEIGHT=480
AVATAR_OUTPUT_FPS=30

# ─── Application Settings ─────────────────────────────────────────
AVATAR_IMAGE_PATH=static/avatars/default.png
AVATAR_DEBUG=false
AVATAR_HOST=127.0.0.1
AVATAR_PORT=8000

# ─── Virtual Device Names ─────────────────────────────────────────
# Leave empty to auto-detect. Set explicitly if auto-detect picks wrong device.
# Camera: determined by backend (OBS Virtual Camera, v4l2loopback, etc.)
# Microphone: partial match against audio output device names
AVATAR_VIRTUAL_CAMERA=
AVATAR_VIRTUAL_MIC=
